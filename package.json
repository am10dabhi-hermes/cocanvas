{
  "name": "cocanvas",
  "version": "0.1.8",
  "description": "CoCanvas — a local-first collaborative canvas for reviewing Markdown and HTML documents with your AI agent. Inspired by Roughdraft.",
  "license": "MIT",
  "author": "Ananth Dabhi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/am10dabhi-hermes/cocanvas.git"
  },
  "bin": {
    "cocanvas": "./packages/server/bin/cocanvas.mjs",
    "roughdraft": "./packages/server/bin/roughdraft.mjs"
  },
  "scripts": {
    "dev:setup": "./scripts/setup.sh",
    "setup": "./scripts/setup.sh",
    "start": "./scripts/run.sh",
    "dev": "node scripts/dev.mjs",
    "dev:install-cli": "node scripts/install-dev-cli.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "lint": "biome check . --assist-enabled=false",
    "lint:fix": "biome check --write . --assist-enabled=false",
    "test:selectors": "node scripts/check-test-selectors.mjs",
    "unused": "knip --no-progress",
    "format": "biome format --write .",
    "test": "pnpm --filter @roughdraft/rfm test && pnpm --filter @roughdraft/app test && pnpm --filter @roughdraft/server test",
    "test:e2e": "playwright test --config packages/app/playwright.config.ts",
    "test:smoke": "playwright test --config packages/app/playwright.config.ts --grep @smoke",
    "test:coverage": "pnpm --filter @roughdraft/app exec vitest run --coverage && pnpm --filter @roughdraft/server exec vitest run --coverage",
    "check": "pnpm lint && pnpm test:selectors && pnpm test && pnpm build",
    "build": "pnpm --filter @roughdraft/rfm build && pnpm --filter @roughdraft/app build && pnpm --filter @roughdraft/server build",
    "preview": "node packages/server/bin/cocanvas.mjs open README.md"
  },
  "files": [
    "packages/app/dist",
    "packages/rfm/dist",
    "packages/rfm/package.json",
    "packages/server/dist",
    "packages/server/bin",
    "packages/server/defaults.mjs",
    "packages/server/defaults.d.mts",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "@roughdraft/rfm": "file:packages/rfm",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "knip": "^6.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
